# Top Video Generator - Environment Configuration
# Copy this file to .env and fill in your actual values
# File paths below are interpreted from the repository root.
# Run uv, make, and docker compose commands from the repository root.

# Environment
TOP_MUSIC_ENV=development
OAUTHLIB_INSECURE_TRANSPORT=1

# Core Settings
TOP_MUSIC_DAYS_BETWEEN_TOP=7
TOP_MUSIC_APP_SECRET_KEY=your-secret-key-here
TOP_MUSIC_ADMIN_PASSWORD=your-admin-panel-password
TOP_MUSIC_THREADS_WORKERS=1
TOP_MUSIC_CPU_WORKERS=1
TOP_MUSIC_LOG_FILE_PATH=logs/top_music.log
TOP_MUSIC_SCHEDULER_FETCH_HOUR=15
TOP_MUSIC_SCHEDULER_FETCH_MINUTE=0
TOP_MUSIC_SCHEDULER_VERTICAL_PUBLISH_HOUR=16
TOP_MUSIC_SCHEDULER_VERTICAL_PUBLISH_MINUTE=0
TOP_MUSIC_SCHEDULER_WEEKLY_PUBLISH_HOUR=17
TOP_MUSIC_SCHEDULER_WEEKLY_PUBLISH_MINUTE=0
TOP_MUSIC_SCHEDULER_WEEKLY_PUBLISH_DAY_OF_WEEK=5
TOP_MUSIC_SCHEDULER_POLL_INTERVAL_SECONDS=60
TOP_MUSIC_SCHEDULER_HEARTBEAT_FILE=run/top-video-generator-scheduler-heartbeat.json
TOP_MUSIC_SCHEDULER_HEARTBEAT_STALE_SECONDS=10800
TOP_MUSIC_SCHEDULER_LOCK_FILE=run/top-video-generator-scheduler.lock

# YouTube API Configuration
TOP_MUSIC_YT_CLIENT_SECRET_FILE=secrets/yt_client_secret.json
TOP_MUSIC_YT_REDIRECT_URI=https://your-domain.com/yt_auth/
# Required: fetch and web flows fail fast if this region is missing or empty.
TOP_MUSIC_YT_SEARCH_REGION_CODE=IN
TOP_MUSIC_YT_SEARCH_LANGUAGE_CODE=hi
TOP_MUSIC_YT_SEARCH_CATEGORY_CODE=10
TOP_MUSIC_YT_AUTH_USER_ID=your-yt-client-id
TOP_MUSIC_YT_TAGS=tag1,tag2,tag3
TOP_MUSIC_YT_TITLE_TEMPLATE="@@TOP_DATE@@ #Music #Top: Best Songs @@HASHTAGS@@"
TOP_MUSIC_YT_DESCRIPTION_TEMPLATE="@@TOP_DATE@@ Most Viewed Songs:\n\n@@VIDEO_LIST@@\n\nThanks for watching!"
TOP_MUSIC_YT_PLAYLIST_ID_DAILY=your-daily-playlist-id
TOP_MUSIC_YT_PLAYLIST_ID_WEEKLY=your-weekly-playlist-id
TOP_MUSIC_YT_PLAYLIST_ID_LINKS_ORIGINAL=your-links-playlist-id

# TikTok API Configuration
TOP_MUSIC_TIKTOK_CLIENT_KEY=your-tiktok-client-key
TOP_MUSIC_TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TOP_MUSIC_TIKTOK_REDIRECT_URI=https://your-domain.com/tiktok_auth/
TOP_MUSIC_TIKTOK_APP_ID=your-tiktok-app-id
TOP_MUSIC_TIKTOK_USER_OPENID=your-tiktok-openid

# Spotify API Configuration
TOP_MUSIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
TOP_MUSIC_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
TOP_MUSIC_SPOTIFY_REDIRECT_URI=https://your-domain.com/spotify_auth/
TOP_MUSIC_SPOTIFY_USER_ID=your-spotify-user-id
TOP_MUSIC_SPOTIFY_PLAYLIST_ORIGINAL=your-spotify-playlist-id

# Instagram Configuration
TOP_MUSIC_INSTAGRAM_CLIENT_USERNAME=your-instagram-username
TOP_MUSIC_INSTAGRAM_CLIENT_PASSWORD=your-instagram-password
TOP_MUSIC_INSTAGRAM_CLIENT_SESSION_FILE=secrets/instagram_session.json
# Optional (development only): use certifi CA bundle for corporate VPN/proxy SSL chains.
TOP_MUSIC_INSTAGRAM_DEV_USE_CERTIFI=false

# Video Templates and Assets
TOP_MUSIC_VIDEO_TEMPLATE_END_SCREEN_FILE=src/resources/video_end_screen.mp4
TOP_MUSIC_VIDEO_TEMPLATE_START_SCREEN_FILE=src/resources/video_start_screen.mp4
TOP_MUSIC_VIDEO_TEMPLATE_FILE=src/resources/video_template.mp4
TOP_MUSIC_VIDEO_TEMPLATE_VERTICAL_FILE=src/resources/video_template_vertical.mp4
TOP_MUSIC_VIDEO_TEMPLATE_THUMBNAIL_FILE=src/resources/video_thumbnail.png
TOP_MUSIC_VIDEO_TEMPLATE_THUMBNAIL_FONT_FILE=src/resources/fonts/Montserrat-ExtraBold.ttf
TOP_MUSIC_VIDEO_GENERATED_FOLDER=videos

# Database Files
TOP_MUSIC_DB_TIMESERIES_FILE=db/db_timeseries.csv
TOP_MUSIC_DB_VIDEO_FILE=db/db_video.json
TOP_MUSIC_DB_AUTH_FILE=db/db_auth.json
TOP_MUSIC_DB_RELEASE_FILE=db/db_release.json
# Deprecated legacy shared store path, kept only for one-shot migration/compatibility.
TOP_MUSIC_DB_DATA_FILE=db/db_data.json
